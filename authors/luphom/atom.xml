		data-armory-30691-stat=&quot;1077&quot;&gt;&lt;&#x2F;span&gt;&lt;&#x2F;td&gt;
	&lt;td&gt;Spear&lt;&#x2F;td&gt;
	&lt;td&gt;Berserker&#x27;s&lt;&#x2F;td&gt;
	&lt;td&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot;
