&lt;tr&gt;&lt;td&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot;
	data-armory-ids=&quot;91234&quot;
	data-armory-91234-stat=&quot;1268&quot;&gt;&lt;&#x2F;span&gt;&lt;&#x2F;td&gt;&lt;td&gt;Ring&lt;&#x2F;td&gt;&lt;td&gt; Viper&#x27;s&lt;&#x2F;td&gt;&lt;&#x2F;tr&gt;
&lt;tr&gt;&lt;td&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot;
	data-armory-ids=&quot;100153&quot;&gt;&lt;&#x2F;span&gt;&lt;&#x2F;td&gt;&lt;td&gt;Relic&lt;&#x2F;td&gt;&lt;td&gt; Fractal &lt;&#x2F;td&gt;&lt;&#x2F;tr&gt;&lt;&#x2F;tbody&gt;&lt;&#x2F;table&gt;
&lt;hr&#x2F;&gt;
&lt;p&gt;Start by adding Viper Pieces until your condi duration is about 67%. You can fill the remaining slots with Sinister or Grieving gear.&lt;&#x2F;p&gt;
&lt;h4 id=&quot;food-and-utility-and-infusions&quot;&gt;Food and Utility and Infusions&lt;&#x2F;h4&gt;
&lt;ul&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot; data-armory-ids=&quot;91878&quot;&gt;&lt;&#x2F;span&gt; Cilantro and Cured Meat Flatbread&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot; data-armory-ids=&quot;48917&quot;&gt;&lt;&#x2F;span&gt; Toxic Tuning Crystal&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot; data-armory-ids=&quot;39619&quot;&gt;&lt;&#x2F;span&gt; Malign +5 Agony Infusion (optional)&lt;&#x2F;li&gt;
&lt;&#x2F;ul&gt;
&lt;hr &#x2F;&gt;
&lt;h2 id=&quot;build&quot;&gt;Build&lt;&#x2F;h2&gt;
&lt;pre data-lang=&quot;chatlink&quot; class=&quot;language-chatlink z-code&quot;&gt;&lt;code class=&quot;language-chatlink&quot; data-lang=&quot;chatlink&quot;&gt;&lt;span class=&quot;z-source z-chatlink&quot;&gt;&lt;span class=&quot;z-punctuation z-definition z-string z-begin&quot;&gt;[&amp;amp;&lt;&#x2F;span&gt;DQMGJyY5SyYqDwAAWh0AAIIdAAAiAQAAex0AAAAAAAAAAAAAAAAAAAAAAAACCQE2AAA=&lt;span class=&quot;z-punctuation z-definition z-string z-end&quot;&gt;]&lt;&#x2F;span&gt;
&lt;&#x2F;span&gt;&lt;&#x2F;code&gt;&lt;&#x2F;pre&gt;
&lt;hr &#x2F;&gt;
&lt;div data-armory-embed=&#x27;skills&#x27; data-armory-ids=&#x27;21659,77209,76908,5836,76993&#x27;&gt;&lt;&#x2F;div&gt;&lt;div data-armory-embed=&#x27;specializations&#x27; data-armory-ids=&#x27;6,38,75&#x27; data-armory-6-traits=&#x27;1882,482,505&#x27; data-armory-38-traits=&#x27;1878,2006,433&#x27; data-armory-75-traits=&#x27;2395,2383,2387&#x27;&gt;&lt;&#x2F;div&gt;
&lt;p&gt;&lt;a rel=&quot;noopener&quot; target=&quot;_blank&quot; href=&quot;https:&#x2F;&#x2F;gw2skills.net&#x2F;editor&#x2F;?PeQEQLTgZn2mZJs7KdcWynlKQ7xnOA-DSRYfBFYGFc+nRcSgOUAK8YQACXD8aSxZFoC-e&quot;&gt;GW2Skills Link&lt;&#x2F;a&gt;&lt;&#x2F;p&gt;
&lt;h2 id=&quot;rotation&quot;&gt;Rotation&lt;&#x2F;h2&gt;
&lt;h4 id=&quot;granting-alacrity&quot;&gt;Granting Alacrity&lt;&#x2F;h4&gt;
&lt;p&gt;You give Alacrity with Morph Skills:&lt;&#x2F;p&gt;
&lt;blockquote&gt;
&lt;ol&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76806&quot;&gt;&lt;&#x2F;span&gt; Offensive Protocol: Obliterate&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76815&quot;&gt;&lt;&#x2F;span&gt; Offensive Protocol: Pierce&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;77163&quot;&gt;&lt;&#x2F;span&gt; Defensive Protocol: Thorns&lt;&#x2F;li&gt;
&lt;&#x2F;ol&gt;
&lt;&#x2F;blockquote&gt;
&lt;blockquote&gt;
&lt;ul&gt;
&lt;li&gt;&lt;small&gt;You may replace &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76815&quot;&gt;&lt;&#x2F;span&gt; Offensive Protocol: Pierce with another protocol of choice for additional utility.&lt;&#x2F;small&gt;&lt;&#x2F;li&gt;
&lt;li&gt;&lt;small&gt;You should use these skills on cooldown to ensure Alacrity doesn&#x27;t drop.&lt;&#x2F;small&gt;&lt;&#x2F;li&gt;
&lt;li&gt;&lt;small&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76806&quot;&gt;&lt;&#x2F;span&gt; Offensive Protocol: Obliterate and &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;77163&quot;&gt;&lt;&#x2F;span&gt; Defensive Protocol: Thorns are your main damage buffs.&lt;&#x2F;small&gt;&lt;&#x2F;li&gt;
&lt;&#x2F;ul&gt;
&lt;&#x2F;blockquote&gt;
&lt;h4 id=&quot;dps-rotation&quot;&gt;DPS Rotation&lt;&#x2F;h4&gt;
&lt;ol&gt;
&lt;li&gt;Precast &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;5836&quot;&gt;&lt;&#x2F;span&gt; Flame Turret and &lt;strong&gt;DO NOT&lt;&#x2F;strong&gt; &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;5985&quot;&gt;&lt;&#x2F;span&gt; Detonate Flame Turret&lt;&#x2F;li&gt;
&lt;li&gt;Use all your skills off-cooldown except your non-alac CC and healing skills&lt;&#x2F;li&gt;
&lt;&#x2F;ol&gt;
&lt;h4 id=&quot;cc-skills&quot;&gt;CC skills&lt;&#x2F;h4&gt;
&lt;ol&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;21661&quot;&gt;&lt;&#x2F;span&gt; Static Shock (AED Toolbelt)&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;72977&quot;&gt;&lt;&#x2F;span&gt; Roiling Skies (Spear 4)&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76815&quot;&gt;&lt;&#x2F;span&gt; Offensive Protocol: Pierce (used in DPS rotation)&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76993&quot;&gt;&lt;&#x2F;span&gt; Flux State (used in DPS rotation)&lt;&#x2F;li&gt;
&lt;&#x2F;ol&gt;
&lt;h4 id=&quot;sustainability&quot;&gt;Sustainability&lt;&#x2F;h4&gt;
&lt;ol&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76908&quot;&gt;&lt;&#x2F;span&gt; Liquid State is an evade stance&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;21659&quot;&gt;&lt;&#x2F;span&gt; A.E.D. can bypass many mechanics.&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;traits&quot; data-armory-ids=&quot;2366&quot;&gt;&lt;&#x2F;span&gt; Stainless Steel is useful for additional heals&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;traits&quot; data-armory-ids=&quot;2395&quot;&gt;&lt;&#x2F;span&gt; Innervating Alloy can be used for condi cleanses&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot; data-armory-ids=&quot;106364&quot;&gt;&lt;&#x2F;span&gt; Relic of the Biomancer or Mist Stranger for Open-world&lt;&#x2F;li&gt;
&lt;&#x2F;ol&gt;
&lt;h2 id=&quot;video&quot;&gt;Video&lt;&#x2F;h2&gt;
&lt;div class=&quot;yv&quot;&gt;
    &lt;iframe src=&quot;https:&#x2F;&#x2F;www.youtube-nocookie.com&#x2F;embed&#x2F;3c9o7JkDv6M&quot; title=&quot;Youtube&quot; class=&quot;yvi&quot; webkitallowfullscreen mozallowfullscreen allowfullscreen&gt;&lt;&#x2F;iframe&gt;
&lt;&#x2F;div&gt;
&lt;p&gt;This build is performed with Ascended Gear, food, utilities and no infusions.&lt;&#x2F;p&gt;
