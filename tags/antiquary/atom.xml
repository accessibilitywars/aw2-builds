&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Trinkets&lt;&#x2F;th&gt;&lt;th&gt;Type&lt;&#x2F;th&gt;&lt;th&gt;Stat&lt;&#x2F;th&gt;&lt;&#x2F;tr&gt;&lt;&#x2F;thead&gt;&lt;tbody&gt;
&lt;tr&gt;&lt;td&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot;
	data-armory-ids=&quot;93105&quot;
	data-armory-93105-stat=&quot;1077&quot;&gt;&lt;&#x2F;span&gt;&lt;&#x2F;td&gt;&lt;td&gt;Ring&lt;&#x2F;td&gt;&lt;td&gt; Berserker&#x27;s&lt;&#x2F;td&gt;&lt;&#x2F;tr&gt;
&lt;tr&gt;&lt;td&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot;
	data-armory-ids=&quot;91234&quot;
	data-armory-91234-stat=&quot;1077&quot;&gt;&lt;&#x2F;span&gt;&lt;&#x2F;td&gt;&lt;td&gt;Ring&lt;&#x2F;td&gt;&lt;td&gt; Berserker&#x27;s&lt;&#x2F;td&gt;&lt;&#x2F;tr&gt;
&lt;tr&gt;&lt;td&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot;
	data-armory-ids=&quot;100916&quot;&gt;&lt;&#x2F;span&gt;&lt;&#x2F;td&gt;&lt;td&gt;Relic&lt;&#x2F;td&gt;&lt;td&gt; Thief &lt;&#x2F;td&gt;&lt;&#x2F;tr&gt;&lt;&#x2F;tbody&gt;&lt;&#x2F;table&gt;
&lt;hr&#x2F;&gt;
&lt;blockquote&gt;
&lt;ul&gt;
&lt;li&gt;Compared to other build guides, addition concentration is added to this guide to allow easier alacrity uptime. You may add even more Diviner&#x27;s pieces with minimal loss of DPS.&lt;&#x2F;li&gt;
&lt;&#x2F;ul&gt;
&lt;&#x2F;blockquote&gt;
&lt;h4 id=&quot;weapon-swap-options&quot;&gt;Weapon Swap Options&lt;&#x2F;h4&gt;
&lt;p&gt;Using dagger&#x2F;rifle with &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76582&quot;&gt;&lt;&#x2F;span&gt; Metal Legion Guitar will result in a moderate DPS increase and better initiative management.&lt;&#x2F;p&gt;
&lt;h4 id=&quot;food-and-utility&quot;&gt;Food and Utility&lt;&#x2F;h4&gt;
&lt;ul&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot; data-armory-ids=&quot;91805&quot;&gt;&lt;&#x2F;span&gt; Cilantro Lime Sous-Vide Steak&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot; data-armory-ids=&quot;9443&quot;&gt;&lt;&#x2F;span&gt; Superior Sharpening Stone&lt;&#x2F;li&gt;
&lt;&#x2F;ul&gt;
&lt;h2 id=&quot;build&quot;&gt;Build&lt;&#x2F;h2&gt;
&lt;h4 id=&quot;alac-dps-optimised&quot;&gt;Alac DPS (Optimised)&lt;&#x2F;h4&gt;
&lt;pre data-lang=&quot;chatlink&quot; class=&quot;language-chatlink z-code&quot;&gt;&lt;code class=&quot;language-chatlink&quot; data-lang=&quot;chatlink&quot;&gt;&lt;span class=&quot;z-source z-chatlink&quot;&gt;&lt;span class=&quot;z-punctuation z-definition z-string z-begin&quot;&gt;[&amp;amp;&lt;&#x2F;span&gt;DQUjGxw9TS8MAQAAWR0AAGAdAAAzAQAAfB0AAAAAAAAAAAAAAAAAAAAAAAACWQA2AAA=&lt;span class=&quot;z-punctuation z-definition z-string z-end&quot;&gt;]&lt;&#x2F;span&gt;
&lt;&#x2F;span&gt;&lt;&#x2F;code&gt;&lt;&#x2F;pre&gt;
&lt;hr &#x2F;&gt;
&lt;div data-armory-embed=&#x27;skills&#x27; data-armory-ids=&#x27;13027,76725,77230,13046,77255&#x27;&gt;&lt;&#x2F;div&gt;&lt;div data-armory-embed=&#x27;specializations&#x27; data-armory-ids=&#x27;35,28,77&#x27; data-armory-35-traits=&#x27;1268,1272,1904&#x27; data-armory-28-traits=&#x27;1245,1704,1269&#x27; data-armory-77-traits=&#x27;2346,2350,2393&#x27;&gt;&lt;&#x2F;div&gt;
&lt;h2 id=&quot;rotation-and-utilities&quot;&gt;Rotation and Utilities&lt;&#x2F;h2&gt;
&lt;ol&gt;
&lt;li&gt;Use &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76725&quot;&gt;&lt;&#x2F;span&gt; Stone Summit Cannon and its backfire off-cooldown&lt;&#x2F;li&gt;
&lt;li&gt;Use &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;77397&quot;&gt;&lt;&#x2F;span&gt; Skritt Swipe and &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;77255&quot;&gt;&lt;&#x2F;span&gt; Skritt Scuffle off-cooldown
&lt;ul&gt;
&lt;li&gt;use your stolen skills charges except for &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76582&quot;&gt;&lt;&#x2F;span&gt; Metal Legion Guitar for alacrity&lt;&#x2F;li&gt;
&lt;li&gt;try to catch different stolen skills, you may prioritise skills that provide power&#x2F;strike damage&#x2F;initiative&lt;&#x2F;li&gt;
&lt;li&gt;use &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76582&quot;&gt;&lt;&#x2F;span&gt; Metal Legion Guitar with &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;13005&quot;&gt;&lt;&#x2F;span&gt; Backstab if weapon swap is desired (optional, see SC guide)&lt;&#x2F;li&gt;
&lt;&#x2F;ul&gt;
&lt;&#x2F;li&gt;
&lt;li&gt;Use all your initiative on &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;29911&quot;&gt;&lt;&#x2F;span&gt; Weakening Whirl (Staff 2)&lt;&#x2F;li&gt;
&lt;li&gt;Use &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;77230&quot;&gt;&lt;&#x2F;span&gt; Canach-Coin Toss if you have nothing better to do or replace it with another utility, do not backfire this.&lt;&#x2F;li&gt;
&lt;&#x2F;ol&gt;
&lt;blockquote&gt;
&lt;ul&gt;
&lt;li&gt;&lt;small&gt;Use &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;77255&quot;&gt;&lt;&#x2F;span&gt; Skritt Scuffle when &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;77397&quot;&gt;&lt;&#x2F;span&gt; Skritt Swipe is recharging&lt;&#x2F;small&gt;&lt;&#x2F;li&gt;
&lt;li&gt;&lt;small&gt;Avoid &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;77397&quot;&gt;&lt;&#x2F;span&gt; Skritt Swipe when &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;77255&quot;&gt;&lt;&#x2F;span&gt; Skritt Scuffle is active&lt;&#x2F;small&gt;&lt;&#x2F;li&gt;
&lt;&#x2F;ul&gt;
&lt;&#x2F;blockquote&gt;
&lt;h4 id=&quot;cc-options&quot;&gt;CC options&lt;&#x2F;h4&gt;
&lt;ul&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76582&quot;&gt;&lt;&#x2F;span&gt; Metal Legion Guitar&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;30210&quot;&gt;&lt;&#x2F;span&gt; Hook Strike (stealth&#x2F;guitar)&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;71802&quot;&gt;&lt;&#x2F;span&gt; Helmet Breaker&lt;&#x2F;li&gt;
&lt;&#x2F;ul&gt;
&lt;blockquote&gt;
&lt;ul&gt;
&lt;li&gt;&lt;small&gt;Hook strike is a powerful CC skill that does not require initiative to cast. This is especially efficient when &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76582&quot;&gt;&lt;&#x2F;span&gt; Metal Legion Guitar is used, giving three charges without the need for stealth.&lt;&#x2F;small&gt;&lt;&#x2F;li&gt;
&lt;&#x2F;ul&gt;
&lt;&#x2F;blockquote&gt;
&lt;h4 id=&quot;sustainability-for-solo-ow&quot;&gt;Sustainability for Solo&#x2F;OW&lt;&#x2F;h4&gt;
&lt;p&gt;This build has a lot of sustainability through its baseline traits &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;traits&quot; data-armory-ids=&quot;2337&quot;&gt;&lt;&#x2F;span&gt; Magpie&#x27;s Defense and &lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;traits&quot; data-armory-ids=&quot;2362&quot;&gt;&lt;&#x2F;span&gt; Enterprising Aristocrat.&lt;&#x2F;p&gt;
&lt;p&gt;You may equip the following for extra:&lt;&#x2F;p&gt;
&lt;ul&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot; data-armory-ids=&quot;101955&quot;&gt;&lt;&#x2F;span&gt; Relic of Zakiros&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;skills&quot; data-armory-ids=&quot;76879&quot;&gt;&lt;&#x2F;span&gt; Emergency Jade Shield&lt;&#x2F;li&gt;
&lt;li&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;traits&quot; data-armory-ids=&quot;1702&quot;&gt;&lt;&#x2F;span&gt; Invigorating Precision&lt;&#x2F;li&gt;
&lt;&#x2F;ul&gt;
&lt;h4 id=&quot;benchmark&quot;&gt;Benchmark&lt;&#x2F;h4&gt;
&lt;p&gt;The benchmark can vary greatly depending on which stolen skills you get. The numbers are not grinded for and it is likely you will achieve higher DPS than our attempts.&lt;&#x2F;p&gt;
