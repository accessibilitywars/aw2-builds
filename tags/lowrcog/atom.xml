&lt;tr&gt;
	&lt;td&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot; s
		data-armory-ids=&quot;97165&quot;
		data-armory-97165-upgrades=&quot;44947&quot;
		data-armory-97165-stat=&quot;1265&quot;&gt;&lt;&#x2F;span&gt;&lt;&#x2F;td&gt;
	&lt;td&gt;Focus&lt;&#x2F;td&gt;
	&lt;td&gt;Minstrel&#x27;s&lt;&#x2F;td&gt;
	&lt;td&gt;&lt;span class=&quot;armory-inline&quot; data-armory-embed=&quot;items&quot;
		data-armory-ids=&quot;44947&quot;&gt;&lt;&#x2F;span&gt; Renewal&lt;&#x2F;td&gt;
